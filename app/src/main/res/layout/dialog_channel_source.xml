<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:textSize="19sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/play_timeout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自动换源超时时间"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/btn_close_auto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_select"
                    android:focusable="true"
                    android:text="关闭"
                    android:textAllCaps="false"
                    android:textColor="@color/tv_select" />

                <Button
                    android:id="@+id/btn_time_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_select"
                    android:focusable="true"
                    android:text="5秒"
                    android:textAllCaps="false"
                    android:textColor="@color/tv_select" />

                <Button
                    android:id="@+id/btn_time_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_select"
                    android:focusable="true"
                    android:text="8秒"
                    android:textAllCaps="false"
                    android:textColor="@color/tv_select" />

                <Button
                    android:id="@+id/btn_time_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_select"
                    android:focusable="true"
                    android:text="10秒"
                    android:textAllCaps="false"
                    android:textColor="@color/tv_select" />

                <Button
                    android:id="@+id/btn_time_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_select"
                    android:focusable="true"
                    android:text="15秒"
                    android:textAllCaps="false"
                    android:textColor="@color/tv_select" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_horizontal"
                android:text="上下选择,Ok(确认)键修改,左右方向键快速换源\n老设备自动换源时间建议设置长一点" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_type"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>

</layout>