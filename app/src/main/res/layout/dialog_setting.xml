<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="30dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="方向键选择，确认键按下(修改)" />

                <Button
                    android:id="@+id/btn_back"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_select"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="返回"
                    android:textSize="19sp" />

                <Button
                    android:id="@+id/btn_exit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_select"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="退出软件"
                    android:textSize="19sp" />

                <Button
                    android:id="@+id/btn_webview_debug"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_select"
                    android:focusable="true"
                    android:padding="10dp"
                    android:text="WebView更新(播放问题)"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="19sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_home"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_select"
                    android:focusable="true"
                    android:padding="10dp"
                    android:text="主页默认搜索页"
                    android:textColor="@color/white"
                    android:textSize="19sp"
                    tools:checked="true" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_cctv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_select"
                    android:focusable="true"
                    android:padding="10dp"
                    android:text="使用CCTV源"
                    android:textColor="@color/white"
                    android:textSize="19sp"
                    android:visibility="gone"
                    tools:checked="true" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_slide_switch_channel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_select"
                    android:focusable="true"
                    android:padding="10dp"
                    android:text="滑动切台换源"
                    android:textColor="@color/white"
                    android:textSize="19sp"
                    tools:checked="true" />

                <Button
                    android:id="@+id/btn_check_update"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_select"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="检查更新"
                    android:textSize="19sp" />

                <Button
                    android:id="@+id/btn_check_update_custom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_select"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="手动更新(电视点我)"
                    android:textSize="19sp" />

                <Button
                    android:id="@+id/btn_remote_install"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_select"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="给远程设备安装"
                    android:textSize="19sp" />

                <Button
                    android:id="@+id/btn_more_setting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_select"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="更多设置"
                    android:textSize="19sp" />


                <Button
                    android:id="@+id/btn_donate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_select"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="捐赠我"
                    android:textSize="19sp" />

                <Button
                    android:id="@+id/btn_faq"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_select"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="常见问题解答"
                    android:textSize="19sp" />

                <Button
                    android:id="@+id/btn_feedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_select"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="问题反馈"
                    android:textSize="19sp" />

                <Button
                    android:id="@+id/btn_help"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_select"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="使用帮助"
                    android:textSize="19sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_gravity="center"
                android:paddingVertical="30dp"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent">

                <TextView
                    android:textColor="@android:color/holo_red_light"
                    android:text="默认OK(确认)键换台,左右方向键换源,长按OK键收藏"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <ImageView
                    android:layout_marginTop="10dp"
                    android:src="@mipmap/ic_launcher_round"
                    android:layout_width="100dp"
                    android:layout_height="100dp" />

                <TextView
                    android:textSize="19sp"
                    android:layout_marginTop="10dp"
                    android:text="@string/app_name"
                    android:id="@+id/tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="作者: 冬日暖雨"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:gravity="center_horizontal"
                    android:text="App开放源代码，没有任何病毒，你也可以自己编译！\nGitee、Github: 搜索 DongYuTVWeb\n公众号: 冬日暖雨\nQQ交流反馈群: 1038112042"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:textSize="19sp"
                    android:layout_marginTop="10dp"
                    tools:text="IP地址:192.168.1.0:12345"
                    android:id="@+id/tv_ip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:textSize="14sp"
                    android:layout_marginTop="10dp"
                    android:text="声明: 直播内容为互联网网站内容，本App不提供具体直播服务"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <ImageView
                    android:layout_marginTop="10dp"
                    android:id="@+id/iv_qrcode2"
                    android:layout_width="150dp"
                    android:layout_height="150dp" />

                <TextView
                    android:text="开发不易，如果觉得App好用欢迎扫码赞赏我，感谢您的支持！"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>


</layout>